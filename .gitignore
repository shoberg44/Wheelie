# =========================================
# 1. Node.js & Frontend (React / Tailwind)
# =========================================
# Dependencies
node_modules/
.pnp
.pnp.js

# Production builds
dist/
build/
out/

# Environment variables (Never commit secrets!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# NPM / Yarn / PNPM logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================================
# 2. Rust & Tauri Engine (Backend)
# =========================================
# Compiled Rust binaries and cache (Massive files)
src-tauri/target/
target/

# Cargo backup files
**/*.rs.bk

# =========================================
# 3. Databases & AI Storage (CRITICAL)
# =========================================
# Prevent uploading user data or massive pre-packaged DBs
# unless explicitly whitelisted later.

# SQLite relational data
*.sqlite
*.sqlite3
*.db
*.db-journal

# Qdrant / Vector local storage
.qdrant/
qdrant_storage/
vector_data/

# =========================================
# 4. Operating System & IDE
# =========================================
# Mac
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# IDEs (VS Code, IntelliJ, etc.)
.vscode/
.idea/
*.suo
*.sln
*.sw?
